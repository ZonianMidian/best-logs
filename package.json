{
	"name": "best-logs",
	"version": "2026.05.17",
	"main": "dist/index.mjs",
	"type": "module",
	"dependencies": {
		"express": "^4.18.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/express": "^4.17.25",
		"@types/node": "^25.8.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-n": "^18.0.1",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.6.0",
		"prettier": "^3.5.3",
		"tsdown": "^0.22.0",
		"tsx": "^4.22.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	},
	"scripts": {
		"build": "tsdown",
		"generate:static": "tsx tools/generateStaticPages.ts",
		"start": "node dist/index.mjs",
		"dev": "tsx src/index.ts",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"typecheck": "tsc --noEmit",
		"fix": "npm run format && npm run lint:fix && npm run typecheck"
	},
	"engines": {
		"node": "^22.17.0 || >=24.0.0"
	},
	"author": "ZonianMidian",
	"description": "API and website that provides the best logs of a user for a Twitch channel",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ZonianMidian/best-logs.git"
	},
	"bugs": {
		"url": "https://github.com/ZonianMidian/best-logs/issues"
	},
	"homepage": "https://github.com/ZonianMidian/best-logs#readme"
